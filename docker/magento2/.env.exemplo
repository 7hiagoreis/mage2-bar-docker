# ---------------------------------------------------------------------
# Configurações do Banco de Dados (MariaDB)
# Utilizado pelo Magento 2 para armazenar produtos, pedidos, clientes
# e todas as informações principais do sistema.
# ---------------------------------------------------------------------

MYSQL_ROOT_PASSWORD=suasenhadomysqlroot
MYSQL_DATABASE=magento_db
MYSQL_USER=magento_user
MYSQL_PASSWORD=suasenhadobancodedados


# ---------------------------------------------------------------------
# Configuração do Redis (Cache e Sessões)
# Usado pelo Magento 2 para melhorar performance, armazenar cache
# e gerenciar sessões de usuários.
# ---------------------------------------------------------------------

REDIS_PASSWORD=suasenhadoredis


# ---------------------------------------------------------------------
# Configuração do OpenSearch (Sistema de Busca)
# Responsável pela pesquisa de produtos dentro do Magento 2.
# Substitui o Elasticsearch nas versões mais recentes.
# ---------------------------------------------------------------------

OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=suasenhaopensearch


# ---------------------------------------------------------------------
# Portas opcionais (úteis para debug ou acesso externo)
# Em muitos casos o Docker já gerencia essas portas internamente.
# ---------------------------------------------------------------------

MYSQL_PORT=3306
REDIS_PORT=6379
OPENSEARCH_PORT=9200
